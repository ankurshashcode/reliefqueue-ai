AI_MODE=mock
OPENAI_COMPAT_BASE_URL=http://localhost:8000/v1
OPENAI_COMPAT_API_KEY=changeme
OPENAI_COMPAT_MODEL=model-name
AI_TIMEOUT_SECONDS=20
AI_MAX_RETRIES=1
AI_MAX_BATCH_SIZE=16
AI_SEND_PRIVATE_TEXT=false

# Optional endpoint compatibility and diagnostics.
AI_REQUEST_LOGGING=false
AI_REDACT_BEFORE_SEND=true
AI_ENDPOINT_LABEL=local-vllm-amd
AI_RESPONSE_FORMAT=json_object
AI_HTTP_USER_AGENT=ReliefQueueAI/0.1 OpenAICompatibleClient

# Optional live integration config checks. Leave unset to SKIP cleanly.
POSTGIS_DSN=
REDIS_URL=
NATS_URL=
RAPIDPRO_API_URL=
RAPIDPRO_API_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
MASKED_CONTACT_PROVIDER=
MASKED_CONTACT_API_KEY=

# Optional local live stack. Safe local demo placeholders only.
RELIEFQUEUE_LIVE_STACK_ENGINE=auto
RELIEFQUEUE_POSTGIS_DSN=postgresql://reliefqueue:reliefqueue@127.0.0.1:54329/reliefqueue
RELIEFQUEUE_REDIS_URL=redis://127.0.0.1:63799/0
RELIEFQUEUE_NATS_URL=nats://127.0.0.1:42299
RELIEFQUEUE_LIVE_STACK_PROJECT=reliefqueue-live

# Public judge-mode safety budgets for live AMD/vLLM endpoints.
# Cost units approximate maximum provider calls: single=2, dossier=3, burst=case_count+2.
RELIEFQUEUE_AMD_DEMO_RATE_WINDOW_SECONDS=3600
RELIEFQUEUE_AMD_DEMO_IP_BUDGET=40
RELIEFQUEUE_AMD_DEMO_GLOBAL_BUDGET=160
RELIEFQUEUE_MAX_JSON_BODY_BYTES=262144
